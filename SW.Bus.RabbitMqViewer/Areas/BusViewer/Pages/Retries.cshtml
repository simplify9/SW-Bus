@page "/bus-viewer/retries"
@attribute [AllowAnonymous]
@using SW.Bus.RabbitMqExtensions
@inject IBusDashboardDataService DataService
@{
    ViewData["Title"]      = "Retry Analysis";
    ViewData["ActivePage"] = "Retries";

    var retries = await DataService.GetRetryAnalysisAsync();
}

@if (!retries.Any())
{
    <article class="bv-card bv-card--ok">
        <p>✓ No retry backlogs detected. All consumers are processing cleanly.</p>
    </article>
}
else
{
    <p class="bv-muted">
        <strong>@retries.Length</strong> consumer(s) have messages in retry queues.
        Auto-refreshes every 10 s.
    </p>

    <div id="bv-retry-table"
         class="bv-table-zone"
         hx-get="/bus-viewer/partials/retries"
         hx-trigger="load, every 10s"
         hx-swap="innerHTML"
         hx-on::after-swap="bvOnSwap(this)">
        <div class="bv-init-loader">
            <div class="bv-spinner"></div>
            <span>Loading retry analysis…</span>
        </div>
    </div>
}

