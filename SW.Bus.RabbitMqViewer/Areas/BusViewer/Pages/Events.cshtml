@page "/bus-viewer/events"
@attribute [AllowAnonymous]
@using SW.Bus.RabbitMqExtensions
@inject IBusDashboardDataService DataService
@{
    ViewData["Title"]      = "Live Operational Events";
    ViewData["ActivePage"] = "Events";
}

<!-- Filter bar -->
<form method="get" class="bv-filter-bar">
    <input type="text"   name="consumer"    placeholder="Consumer name"    value="@Request.Query["consumer"]"    class="bv-filter-input"/>
    <input type="text"   name="messageType" placeholder="Message type"     value="@Request.Query["messageType"]" class="bv-filter-input"/>
    <input type="text"   name="correlationId" placeholder="Correlation ID" value="@Request.Query["correlationId"]" class="bv-filter-input"/>
    <input type="text"   name="traceId"     placeholder="Trace ID"         value="@Request.Query["traceId"]"     class="bv-filter-input"/>
    <select name="eventName" class="bv-filter-select">
        <option value="">All event types</option>
        @foreach (var name in new[] {
            "MessageProcessingStarted","MessageProcessingCompleted","MessageProcessingFailed",
            "MessageRetryScheduled","MessageMovedToDeadLetter",
            "ConsumerConnected","ConsumerDisconnected","QueueBackpressureDetected",
            "PublishStarted","PublishCompleted","PublishFailed" })
        {
            <option value="@name" selected="@(Request.Query["eventName"] == name ? "selected" : null)">@name</option>
        }
    </select>
    <button type="submit" class="bv-btn">Filter</button>
    <a href="/bus-viewer/events" class="bv-btn bv-btn--secondary">Clear</a>
</form>

<!-- Live event feed (polls every 5 s, appends query params) -->
@{
    var qs = new System.Text.StringBuilder("/bus-viewer/partials/events?limit=100");
    foreach (var kv in Request.Query)
        if (!string.IsNullOrEmpty(kv.Value))
            qs.Append($"&{kv.Key}={Uri.EscapeDataString(kv.Value!)}");
}

<div id="bv-event-feed"
     class="bv-table-zone"
     hx-get="@qs"
     hx-trigger="load, every 5s"
     hx-swap="innerHTML"
     hx-on::after-swap="bvOnSwap(this)">
    <div class="bv-init-loader">
        <div class="bv-spinner"></div>
        <span>Loading live events…</span>
    </div>
</div>

