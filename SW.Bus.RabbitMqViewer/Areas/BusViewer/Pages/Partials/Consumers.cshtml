@page "/bus-viewer/partials/consumers"
@attribute [AllowAnonymous]
@using SW.Bus.RabbitMqExtensions
@{ Layout = null; }
@inject IBusDashboardDataService DataService
@{
    var consumers = await DataService.GetConsumerHealthAsync();
}

@if (!consumers.Any())
{
    <p class="bv-muted">No consumers registered.</p>
}
else
{
    <table class="bv-table">
        <thead>
        <tr>
            <th>Status</th>
            <th>Consumer</th>
            <th>Message Type</th>
            <th>Nodes</th>
            <th>Queue</th>
            <th>In-Flight</th>
            <th>Retry</th>
            <th>Dead Letter</th>
            <th>In Rate</th>
            <th>Ack Rate</th>
            <th>Prefetch</th>
            <th>Priority</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var c in consumers.OrderByDescending(x => x.HealthStatus).ThenBy(x => x.Name))
        {
            var tooltipText = BuildCriticalTooltip(c);
            <tr class="bv-row--@c.HealthStatus.ToString().ToLower()">
                <td>
                    @if (c.HealthStatus == AlertSeverity.Critical && !string.IsNullOrEmpty(tooltipText))
                    {
                        <span class="bv-badge bv-badge--critical" data-bv-tooltip="@tooltipText">⚠ Critical</span>
                    }
                    else if (c.HealthStatus == AlertSeverity.Warning)
                    {
                        <span class="bv-badge bv-badge--warning">△ Warning</span>
                    }
                    else
                    {
                        <span class="bv-badge bv-badge--info">✓ Healthy</span>
                    }
                </td>
                <td>@c.Name</td>
                <td>@c.MessageName</td>
                <td class="@(c.TotalNodes == 0 ? "bv-critical" : "")">@c.TotalNodes</td>
                <td class="bv-mono bv-muted bv-small">@c.QueueName</td>
                <td>@c.ProcessingCount</td>
                <td class="@(c.RetryCount > 0 ? "bv-warning" : "")">@c.RetryCount</td>
                <td class="@(c.FailedCount > 0 ? "bv-critical" : "")">@c.FailedCount</td>
                <td>@c.IncomingRate.ToString("F2")</td>
                <td>@c.AckRate.ToString("F2")</td>
                <td>@c.Prefetch</td>
                <td>@(c.Priority > 0 ? c.Priority.ToString() : "-")</td>
            </tr>
        }
        </tbody>
    </table>
}

@functions {
    /// <summary>
    /// Builds a human-readable tooltip explaining why a consumer is in Critical state.
    /// Returns an empty string for non-critical consumers.
    /// </summary>
    private static string BuildCriticalTooltip(ConsumerHealthView c)
    {
        if (c.HealthStatus != AlertSeverity.Critical) return string.Empty;

        var reasons = new System.Text.StringBuilder();

        if (c.TotalNodes == 0)
            reasons.AppendLine("• No active nodes — consumer disconnected.");

        if (c.FailedCount > 0)
            reasons.AppendLine($"• {c.FailedCount:N0} message(s) in dead-letter queue.");

        if (c.RetryCount > 0)
            reasons.AppendLine($"• {c.RetryCount:N0} message(s) in retry queue.");

        if (c.IsBackpressured)
            reasons.AppendLine($"• Queue backpressure ({c.QueueCount:N0} messages waiting).");

        if (c.IncomingRate > 1.0 && c.AckRate < 0.01)
            reasons.AppendLine($"• Publish/Ack imbalance — {c.IncomingRate:F1} msg/s in, ack rate ≈ 0.");

        return reasons.ToString().Trim();
    }
}
